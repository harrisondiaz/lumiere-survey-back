{
  "name": "lumiere-survey-backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "prisma generate && vitest run",
    "test:watch": "prisma generate && vitest",
    "test:coverage": "prisma generate && vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "node-telegram-bot-api": "^0.66.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/node-telegram-bot-api": "^0.64.9",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
