generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SurveyResponse {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  ageRange  String
  country   String
  answers   Json
  ip        String
  userAgent String
  timezone  String
  language  String
  referrer  String
  createdAt DateTime @default(now())
}
